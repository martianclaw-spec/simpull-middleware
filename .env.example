# SimPull Middleware — environment variables
# Copy this file to .env and fill in your values.
# All values can also be set via data/config.json after first run.

# Port the middleware listens on (default: 3005)
PORT=3005

# Full path to your Assetto Corsa installation folder
AC_PATH=C:/Program Files (x86)/Steam/steamapps/common/assettocorsa

# Scan AC content on startup (true/false, default: true)
SCAN_ON_START=true
